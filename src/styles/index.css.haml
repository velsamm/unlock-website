:css
  @import url('https://fonts.googleapis.com/css2?family=Raleway:wght@400;500&display=swap');

  :root {
    --text-color: rgba(31, 31, 31, 1);
    --text-color-white: rgba(255, 255, 255, 1);
    --border-color: rgba(31, 31, 31, 1);
    --circle-color: rgba(31, 31, 31, 1);
    --font-size-title: 60px;
    --services-background: rgba(255, 255, 255, 1);
    --radius: 20px;
    --button-text: rgba(255, 255, 255, 1);
    --button-background: rgba(31, 31, 31, 1);
    --button-radius: 60px;
  }

  footer {
    margin-top: 180px;
  }

  body {
    margin:0;
    background-color: #E5E5E5;
    padding: 40px 60px;
    font-family: 'Raleway', sans-serif;
  }

  ul {
    list-style-type: none;
  }

  .service-market li {
    padding: 36px 48px;
    background-color: var(--services-background);
    margin-bottom: 20px;
    border-radius: var(--radius);
    display: flex;
    align-items: center;
  }

  .service-market li:last-child {
    margin-bottom: 0;
  }

  .service-bank li {
    padding: 36px 48px;
    background-color: var(--services-background);
    margin-bottom: 20px;
    border-radius: var(--radius);
    display: flex;
    align-items: center;
  }

  .service-bank li:last-child {
    margin-bottom: 0;
  }

  footer li {
    margin-bottom: 20px;
    font-weight: 500;
    font-size: 18px;
    line-height: 21px;
  }

  footer li:last-child {
    margin-bottom: 0;
  }

  .d-flex {
    display: flex;
  }

  .row {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
  }

  .column {
    flex-direction: column;
  }

  .col {
    flex: 1 0 0;
  }

  .grow-1 {
    flex-grow: 1;
  }

  .grow-2 {
    flex-grow: 2;
  }

  .justify-content-flex-end {
    justify-content: flex-end;
  }

  .justify-content-space-between {
    justify-content: space-between;
  }

  .justify-content-center {
    justify-content: center;
  }

  .align-items-center {
    align-items: center;
  }

  .align-items-start {
    align-items: flex-start;
  }

  .page-link {
    text-decoration: none;
    color: var(--text-color);
    padding-right: 60px;
  }

  .page-link:last-child {
    padding-right: 0;
  }

  .landing {
    padding: 135px 0 60px;
  }

  .title {
    font-size: var(--font-size-title);
  }

  .title-action {
    margin-bottom: 263px;
  }

  .image-man-on-pc {
    position: absolute;
    right: 60px;
    top: 32%;
    z-index: 1;
  }

  .image-purple-person {
    margin-top: -75px;
  }
  .image-orange-person {
    margin-left: -50px;
    margin-top: 75px;
  }

  .service-title {
    position: relative;
    z-index: 2;
    background-color: var(--services-background);
    padding: 64px 96px 64px 0;
    margin-bottom: 40px;
    border-radius: var(--radius);
  }

  .w-300 {
   width: 300px;
   max-width: 300px;
  }

  .w-full {
    width: 100%;
  }

  .h-100 {
    height: 100%;
  }

  .who-works {
    font-weight: 400;
    font-size: 36px;
    line-height: 42px;
  }

  .help-with {
    padding: 48px;
    background-color: var(--services-background);
    border-radius: var(--radius);
  }

  .help-with span {
    font-size: 24px;
  }

  .help-with .title {
    margin-bottom: 49px;
  }

  .help-with:not(:last-child) {
    margin-right: 40px;
  }

  .service-market {
    border: 2px solid var(--border-color);
    padding: 60px;
    border-radius: var(--radius);
  }

  .circle {
    border-radius: 50%;
    background-color: var(--circle-color);
    width: 15px;
    height: 15px;
    min-width: 15px;
    min-height: 15px;
  }

  .service-item {
    margin-left: 37px;
  }

  .service-item span {
    font-size: 20px;
  }

  .services {
    margin-top: 180px;
  }

  .help-title {
    font-size: var(--font-size-title);
    margin-bottom: 60px;
  }

  .help-left {
    padding-right: 150px;
  }

  .coins {
    padding-right: 100px;
    margin-top: 60px;
  }

  .notes {
    margin: auto;
  }

  .help-subtitle {
    font-size: 36px;
    line-height: 42px;
  }

  .service-bank {
    margin-top: 60px;
    border: 2px solid var(--border-color);
    padding: 60px;
    border-radius: var(--radius);
  }

  .how-we-work {
    margin-top: 180px;
    margin-bottom: 60px;
  }

  .how-we-work span {
    font-size: var(--font-size-title);
  }

  .how-we-work-item {
    padding: 48px;
    background-color: var(--services-background);
    border-radius: var(--radius);
    margin-right: 40px;
  }

  .how-we-work-item .num {
    font-weight: 500;
    font-size: 100px;
    line-height: 117px;
    margin-bottom: 24px;
  }

  .how-we-work-item .title {
    font-size: 32px;
    line-height: 38px;
    margin-bottom: 16px;
  }

  .how-we-work-item .content {
    font-size: 20px;
    line-height: 26px;
  }

  .how-we-work-item:last-child {
    margin-right: 0;
  }

  .price {
    margin-top: 180px;
    margin-bottom: 60px;
    font-size: var(--font-size-title);
  }

  .percent {
    border: 2px solid var(--border-color);
    padding: 16px 60px;
    border-radius: var(--radius);
    margin-right: 60px;
  }

  .percent:last-child {
    margin-right: 0;
  }

  .percent .num {
    font-weight: 500;
    font-size: 100px;
    line-height: 117px;
    margin-bottom: 12px;
  }

  .percent .title {
    font-size: 24px;
    line-height: 38px;
    margin-bottom: 20px;
  }

  .percent .subtitle {
    font-size: 15px;
    line-height: 38px;
    margin-bottom: 20px;
    color: rgba(31, 31, 31, 0.5);
  }

  .result {
    background-color: var(--services-background);
    padding: 48px 60px;
    border-radius: var(--radius);
    margin-right: 60px;
    margin-top: 60px;
  }

  .result .num {
    font-weight: 500;
    font-size: 36px;
    line-height: 42px;
    margin-bottom: 12px;
    }

  .result .title {
    font-weight: 500;
    font-size: 20px;
    line-height: 26px;
    margin-top: 24px;
  }

  .result:last-child {
    margin-right: 0;
  }

  .design-author-title {
    font-weight: 400;
    font-size: 14px;
    line-height: 16px;
    margin-right: 10px;
  }

  .design-author {
    font-weight: 400;
    font-size: 14px;
    line-height: 20px;
  }

  .design-author-block {
    margin-top: 63px;
  }

  .star {
    position: absolute;
    left: 25%;
    margin-top: 70px;
  }

  .star-2 {
    position: absolute;
    right: 10%;
    margin-top: -140px;
  }

  .percent-icon {
    position: absolute;
    left: 57%;
    margin-top: -65px;
  }

  .clocks-icon {
    position: absolute;
    left: 23%;
    margin-top: -75px;
  }

  .check-icon {
    position: absolute;
    left: 90%;
    margin-top: -75px;
  }

  .btn {
    cursor: pointer;
    height: 61px;
    padding: 20px 40px;
    border-radius: var(--button-radius);
    background-color: var(--button-background);
    color: var(--button-text);
    border: none;
    width: 100%;
  }

  .btn-a {
    text-decoration: none;
    cursor: pointer;
    width: 222px;
    height: 61px;
    padding: 20px 40px;
    border-radius: var(--button-radius);
    background-color: var(--button-background);
    color: var(--button-text);
  }

  .tg {
    border: 2px solid var(--border-color);
    padding: 60px;
    border-radius: var(--radius);
    margin-top: 180px;
  }

  .tg span {
    font-weight: 400;
    font-size: 32px;
    line-height: 38px;
  }

  .btn-container {
    margin: 48px 0;
  }

  .tg .question {
    border: 2px solid var(--border-color);
    border-radius: var(--radius);
    color: var(--text-color-white);
    height: 149px;
    max-height: 149px;

    padding: 0 32px;
    display: flex;
    flex-direction: column;
    text-align: left;
    justify-content: center;
  }

  .tg .green {
    background-color: rgba(58, 231, 148, 1);
    color: var(--text-color);
    width: 244px;

    margin-bottom: -65px;
    margin-left: 350px;
    z-index: 3;
  }

  .tg .purple {
    width: 210px;
    background-color: rgba(92, 75, 214, 1);
    margin-left: -55px;
    z-index: 2;
  }

  .tg .orange {
    width: 261px;
    background-color: rgba(251, 73, 3, 1);
    margin-left: 245px;
    margin-top: -70px;
    z-index: 1;
  }

  .tg .question .title {
    font-weight: 800;
    font-size: 30px;
    line-height: 35px;
  }
  .tg .question .content {
    font-weight: 500;
    font-size: 16px;
    line-height: 19px;
  }

  .contact-form {
    margin-top: 180px;
    position: relative;
  }

  .contact-form input {
    padding: 20px 40px;
    border-radius: var(--radius);
    border: none;
    font-size: 18px;
    line-height: 21px;
  }

  .contact-form .col {
    margin-bottom: 21px;
  }

  .contact-form .col:last-child {
    margin-bottom: 0;
  }

  .contact-form .title {
    font-weight: 400;
    font-size: var(--font-size-title);
    line-height: 70px;
  }

  .contact-form .subtitle {
    margin-top: 20px;
    font-weight: 500;
    font-size: 20px;
    line-height: 26px;
  }

  .contact-form form {
    margin-top: 60px;
  }

  .contact-form .arrow {
    display: none;
  }

  .contact-form-content {
    flex-direction: column;
  }

  @media (max-width: 480px) {

  }

  @media (min-width: 480px) {

  }

  @media (min-width: 768px) {

  }

  @media (min-width: 1200px) {
    .contact-form-content {
      flex-direction: row;
    }

    .contact-form .col {
      margin-right: 21px;
    }

    .contact-form .col:last-child {
      margin-right: 0;
    }
  }

  @media (min-width: 1366px) {
    .contact-form .arrow {
      display: block;
      position: absolute;
      right: 36%;
      bottom: 42%;
    }
  }




